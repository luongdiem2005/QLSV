// ============================================================================
//  EduFee - Prisma Schema (MySQL)
//  Hệ thống quản lý đăng ký môn học & thu học phí
//  Gồm 17 model + 1 enum, ghép từ 6 nhóm đã thiết kế ở BƯỚC 3.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===================== NHÓM 1: DANH MỤC NỀN =====================

/// Danh mục tỉnh/thành
model TINH {
  MaTinh  String @id @db.VarChar(10)
  TenTinh String @unique @db.VarChar(100)

  xaList XA[]
}

/// Danh mục xã/phường, gắn với 1 tỉnh
model XA {
  MaXa          String  @id @db.VarChar(10)
  MaTinh        String  @db.VarChar(10)
  TenXa         String  @db.VarChar(100)
  VungSauVungXa Boolean @default(false)
  GhiChu        String? @db.VarChar(255)

  tinh         TINH       @relation(fields: [MaTinh], references: [MaTinh])
  sinhVienList SINHVIEN[]

  @@unique([MaTinh, TenXa])
}

/// Đối tượng ưu tiên & tỷ lệ miễn giảm (QĐ2)
model DOITUONGUUTIEN {
  MaDoiTuong   String  @id @db.VarChar(10)
  TenDoiTuong  String  @unique @db.VarChar(100)
  TyLeMienGiam Decimal @db.Decimal(5, 2)
  GhiChu       String? @db.VarChar(255)

  sinhVienList SINHVIEN[]
}

/// Khoa
model KHOA {
  MaKhoa       String  @id @db.VarChar(10)
  TenKhoa      String  @unique @db.VarChar(150)
  VanPhongKhoa String? @db.VarChar(150)
  GhiChu       String? @db.VarChar(255)

  nganhList  NGANH[]
  monHocList MONHOC[]
}

/// Ngành học, thuộc 1 khoa
model NGANH {
  MaNganh  String  @id @db.VarChar(10)
  TenNganh String  @unique @db.VarChar(150)
  MaKhoa   String  @db.VarChar(10)
  GhiChu   String? @db.VarChar(255)

  khoa            KHOA             @relation(fields: [MaKhoa], references: [MaKhoa])
  sinhVienList    SINHVIEN[]
  chuongTrinhList CHUONGTRINHHOC[]
}

// ===================== NHÓM 2: MÔN HỌC =====================

/// Loại môn học: LT/TH + quy tắc tính tín chỉ và đơn giá (QĐ5/QĐ9)
model LOAIMONHOC {
  MaLoaiMonHoc    String  @id @db.VarChar(10)
  TenLoaiMonHoc   String  @unique @db.VarChar(50)
  SoTietMotTinChi Int
  SoTienMotTinChi Decimal @db.Decimal(12, 2)

  monHocList MONHOC[]
}

/// Môn học. Số tín chỉ = SoTiet / SoTietMotTinChi -> tính ở service, KHÔNG lưu cột
model MONHOC {
  MaMonHoc     String @id @db.VarChar(10)
  TenMonHoc    String @unique @db.VarChar(150)
  MaKhoa       String @db.VarChar(10)
  MaLoaiMonHoc String @db.VarChar(10)
  SoTiet       Int

  khoa       KHOA       @relation(fields: [MaKhoa], references: [MaKhoa])
  loaiMonHoc LOAIMONHOC @relation(fields: [MaLoaiMonHoc], references: [MaLoaiMonHoc])

  monHocTruocList   CT_MONHOCTRUOC[] @relation("MonHocChinh")
  laMonTruocCuaList CT_MONHOCTRUOC[] @relation("MonHocTruoc")
  chuongTrinhList   CHUONGTRINHHOC[]
  monHocMoList      MONHOCMO[]
  ctPhieuDKList     CT_PHIEUDK[]
}

/// Bảng nối môn tiên quyết (n-n tự thân của MONHOC)
model CT_MONHOCTRUOC {
  MaMonHoc      String @db.VarChar(10)
  MaMonHocTruoc String @db.VarChar(10)

  monHoc      MONHOC @relation("MonHocChinh", fields: [MaMonHoc], references: [MaMonHoc])
  monHocTruoc MONHOC @relation("MonHocTruoc", fields: [MaMonHocTruoc], references: [MaMonHoc])

  @@id([MaMonHoc, MaMonHocTruoc])
}

/// Khung chương trình học: ngành học môn nào ở học kỳ thứ mấy
model CHUONGTRINHHOC {
  MaNganh    String  @db.VarChar(10)
  MaMonHoc   String  @db.VarChar(10)
  HocKy      String  @db.VarChar(20)
  KhoaApDung String? @db.VarChar(20)
  GhiChu     String? @db.VarChar(255)

  nganh  NGANH  @relation(fields: [MaNganh], references: [MaNganh])
  monHoc MONHOC @relation(fields: [MaMonHoc], references: [MaMonHoc])

  @@id([MaNganh, MaMonHoc])
}

// ===================== NHÓM 3: NGƯỜI DÙNG & SINH VIÊN =====================

/// Vai trò người dùng - role enum đơn giản
enum VaiTro {
  ADMIN
  PDT
  PTC
  SV
}

/// Hồ sơ sinh viên (BM7)
model SINHVIEN {
  MaSoSinhVien String    @id @db.VarChar(15)
  HoTen        String    @db.VarChar(100)
  NgaySinh     DateTime?
  GioiTinh     String?   @db.VarChar(10)
  SoDienThoai  String?   @db.VarChar(15)
  Email        String?   @unique @db.VarChar(100)
  MaXa         String?   @db.VarChar(10)
  MaNganh      String    @db.VarChar(10)
  MaDoiTuong   String?   @db.VarChar(10)
  TinhTrang    String    @default("Đang học") @db.VarChar(20)

  xa              XA?             @relation(fields: [MaXa], references: [MaXa])
  nganh           NGANH           @relation(fields: [MaNganh], references: [MaNganh])
  doiTuong        DOITUONGUUTIEN? @relation(fields: [MaDoiTuong], references: [MaDoiTuong])
  nguoiDung       NGUOIDUNG?
  phieuDangKyList PHIEUDANGKY[]
}

/// Tài khoản đăng nhập (gồm cả SV). MatKhau lưu HASH bcrypt.
model NGUOIDUNG {
  TenDangNhap  String  @id @db.VarChar(50)
  MatKhau      String  @db.VarChar(255)
  VaiTro       VaiTro
  HoTen        String? @db.VarChar(100)
  MaSoSinhVien String? @unique @db.VarChar(15)
  TrangThai    Boolean @default(true)

  sinhVien SINHVIEN? @relation(fields: [MaSoSinhVien], references: [MaSoSinhVien])
}

// ===================== NHÓM 4: HỌC KỲ & MỞ MÔN =====================

/// Học kỳ năm học (BM8)
model HOCKYNAMHOC {
  MaHKNH        String   @id @db.VarChar(15)
  HocKy         String   @db.VarChar(20)
  NgayBatDau    DateTime
  NgayKetThuc   DateTime
  HanDongHocPhi DateTime

  monHocMoList    MONHOCMO[]
  phieuDangKyList PHIEUDANGKY[]
}

/// Môn được mở trong một học kỳ + sĩ số
model MONHOCMO {
  MaMonHocMo  String @id @db.VarChar(15)
  MaHKNH      String @db.VarChar(15)
  MaMonHoc    String @db.VarChar(10)
  SiSoToiDa   Int    @default(50)
  SiSoHienTai Int    @default(0)

  hocKyNamHoc HOCKYNAMHOC @relation(fields: [MaHKNH], references: [MaHKNH])
  monHoc      MONHOC      @relation(fields: [MaMonHoc], references: [MaMonHoc])

  @@unique([MaHKNH, MaMonHoc])
}

// ===================== NHÓM 5: ĐĂNG KÝ & HỌC PHÍ =====================

/// Phiếu đăng ký học phần của 1 SV trong 1 học kỳ (BM9)
model PHIEUDANGKY {
  MaPhieu          String   @id @db.VarChar(15)
  MaSoSinhVien     String   @db.VarChar(15)
  MaHKNH           String   @db.VarChar(15)
  NgayLapPhieu     DateTime @default(now())
  TongTienDK       Decimal  @default(0) @db.Decimal(12, 2)
  TienMienGiam     Decimal  @default(0) @db.Decimal(12, 2)
  TongTienPhaiDong Decimal  @default(0) @db.Decimal(12, 2)
  SoTienDaDong     Decimal  @default(0) @db.Decimal(12, 2)
  SoTienConLai     Decimal  @default(0) @db.Decimal(12, 2)

  sinhVien      SINHVIEN         @relation(fields: [MaSoSinhVien], references: [MaSoSinhVien])
  hocKyNamHoc   HOCKYNAMHOC      @relation(fields: [MaHKNH], references: [MaHKNH])
  ctPhieuDKList CT_PHIEUDK[]
  phieuThuList  PHIEUTHUHOCPHI[]

  @@unique([MaSoSinhVien, MaHKNH])
  @@index([MaHKNH])
}

/// Chi tiết phiếu đăng ký (n-n PHIEUDANGKY × MONHOC)
model CT_PHIEUDK {
  MaPhieuDK String @db.VarChar(15)
  MaMonHoc  String @db.VarChar(10)

  phieuDangKy PHIEUDANGKY @relation(fields: [MaPhieuDK], references: [MaPhieu])
  monHoc      MONHOC      @relation(fields: [MaMonHoc], references: [MaMonHoc])

  @@id([MaPhieuDK, MaMonHoc])
}

/// Phiếu thu học phí - mỗi lần đóng tiền (QĐ10)
model PHIEUTHUHOCPHI {
  MaPhieuThu   String   @id @db.VarChar(15)
  MaPhieuDK    String   @db.VarChar(15)
  NgayLapPhieu DateTime @default(now())
  SoTienThu    Decimal  @db.Decimal(12, 2)

  phieuDangKy PHIEUDANGKY @relation(fields: [MaPhieuDK], references: [MaPhieu])

  @@index([MaPhieuDK])
}

// ===================== NHÓM 6: THAM SỐ HỆ THỐNG =====================

/// Lưu các quy định thay đổi được (QĐ13) dạng key-value
model THAMSO {
  TenThamSo String @id @db.VarChar(50)
  GiaTri    String @db.VarChar(255)
}
