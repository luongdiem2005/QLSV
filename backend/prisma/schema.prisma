// ============ datasource & generator (khai báo 1 lần cho cả schema) ============
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===================== NHÓM 1: DANH MỤC NỀN =====================

/// Danh mục tỉnh/thành
model TINH {
  MaTinh  String @id @db.VarChar(10)
  TenTinh String @unique @db.VarChar(100)

  xaList XA[] // 1 tỉnh có nhiều xã
}

/// Danh mục xã/phường, gắn với 1 tỉnh
model XA {
  MaXa          String  @id @db.VarChar(10)
  MaTinh        String  @db.VarChar(10)
  TenXa         String  @db.VarChar(100)
  VungSauVungXa Boolean @default(false)
  GhiChu        String? @db.VarChar(255)

  tinh         TINH       @relation(fields: [MaTinh], references: [MaTinh])
  sinhVienList SINHVIEN[] // thêm ở Nhóm có SINHVIEN

  @@unique([MaTinh, TenXa]) // chống trùng tên xã trong cùng tỉnh
}

/// Đối tượng ưu tiên & tỷ lệ miễn giảm (QĐ2)
model DOITUONGUUTIEN {
  MaDoiTuong   String  @id @db.VarChar(10)
  TenDoiTuong  String  @unique @db.VarChar(100)
  TyLeMienGiam Decimal @db.Decimal(5, 2) // 0..100, kiểm tra ở service
  GhiChu       String? @db.VarChar(255)

  sinhVienList SINHVIEN[] // thêm ở Nhóm có SINHVIEN
}

/// Khoa
model KHOA {
  MaKhoa       String  @id @db.VarChar(10)
  TenKhoa      String  @unique @db.VarChar(150)
  VanPhongKhoa String? @db.VarChar(150)
  GhiChu       String? @db.VarChar(255)

  nganhList  NGANH[] // 1 khoa có nhiều ngành (QĐ4)
  monHocList MONHOC[] // thêm ở nhóm Môn học
}

/// Ngành học, thuộc 1 khoa
model NGANH {
  MaNganh  String  @id @db.VarChar(10)
  TenNganh String  @unique @db.VarChar(150)
  MaKhoa   String  @db.VarChar(10)
  GhiChu   String? @db.VarChar(255)

  khoa            KHOA             @relation(fields: [MaKhoa], references: [MaKhoa])
  sinhVienList    SINHVIEN[] // thêm ở nhóm SINHVIEN
  chuongTrinhList CHUONGTRINHHOC[] // thêm ở nhóm Chương trình
}

// ===================== NHÓM 2: MÔN HỌC =====================

/// Loại môn học: LT/TH + quy tắc tính tín chỉ và đơn giá (QĐ5/QĐ9)
model LOAIMONHOC {
  MaLoaiMonHoc    String  @id @db.VarChar(10)
  TenLoaiMonHoc   String  @unique @db.VarChar(50)
  SoTietMotTinChi Int // LT=15, TH=30
  SoTienMotTinChi Decimal @db.Decimal(12, 2) // đơn giá / tín chỉ

  monHocList MONHOC[] // 1 loại áp dụng cho nhiều môn
}

/// Môn học. Số tín chỉ = SoTiet / SoTietMotTinChi -> KHÔNG lưu cột, tính ở service
model MONHOC {
  MaMonHoc     String @id @db.VarChar(10)
  TenMonHoc    String @unique @db.VarChar(150)
  MaKhoa       String @db.VarChar(10)
  MaLoaiMonHoc String @db.VarChar(10)
  SoTiet       Int // > 0, kiểm tra ở service

  khoa       KHOA       @relation(fields: [MaKhoa], references: [MaKhoa])
  loaiMonHoc LOAIMONHOC @relation(fields: [MaLoaiMonHoc], references: [MaLoaiMonHoc])

  // Quan hệ n-n tự thân (môn tiên quyết) qua bảng nối CT_MONHOCTRUOC:
  monHocTruocList   CT_MONHOCTRUOC[] @relation("MonHocChinh") // các môn tiên quyết CỦA môn này
  laMonTruocCuaList CT_MONHOCTRUOC[] @relation("MonHocTruoc") // môn này LÀ tiên quyết của môn khác

  chuongTrinhList CHUONGTRINHHOC[] // môn này nằm trong những chương trình nào
  monHocMoList    MONHOCMO[] // thêm ở Nhóm Học kỳ/Mở môn
  ctPhieuDKList   CT_PHIEUDK[] // thêm ở Nhóm Đăng ký/Học phí
}

/// Bảng nối môn tiên quyết: (MaMonHoc, MaMonHocTruoc) đều trỏ về MONHOC
model CT_MONHOCTRUOC {
  MaMonHoc      String @db.VarChar(10)
  MaMonHocTruoc String @db.VarChar(10)

  monHoc      MONHOC @relation("MonHocChinh", fields: [MaMonHoc], references: [MaMonHoc])
  monHocTruoc MONHOC @relation("MonHocTruoc", fields: [MaMonHocTruoc], references: [MaMonHoc])

  @@id([MaMonHoc, MaMonHocTruoc]) // PK kép, chống khai báo trùng cặp tiên quyết
}

/// Khung chương trình học: ngành học môn nào ở học kỳ thứ mấy
model CHUONGTRINHHOC {
  MaNganh    String  @db.VarChar(10)
  MaMonHoc   String  @db.VarChar(10)
  HocKy      String  @db.VarChar(20)
  KhoaApDung String? @db.VarChar(20)
  GhiChu     String? @db.VarChar(255)

  nganh  NGANH  @relation(fields: [MaNganh], references: [MaNganh])
  monHoc MONHOC @relation(fields: [MaMonHoc], references: [MaMonHoc])

  @@id([MaNganh, MaMonHoc]) // PK kép
}

// ===================== NHÓM 3: NGƯỜI DÙNG & SINH VIÊN =====================

/// Vai trò người dùng — role enum đơn giản (đã chốt thay cho bảng phân quyền động)
enum VaiTro {
  ADMIN
  PDT // Phòng Đào tạo
  PTC // Phòng Tài chính
  SV // Sinh viên
}

/// Hồ sơ sinh viên (BM7)
model SINHVIEN {
  MaSoSinhVien String    @id @db.VarChar(15)
  HoTen        String    @db.VarChar(100)
  NgaySinh     DateTime?
  GioiTinh     String?   @db.VarChar(10)
  SoDienThoai  String?   @db.VarChar(15)
  Email        String?   @unique @db.VarChar(100)
  MaXa         String?   @db.VarChar(10)
  MaNganh      String    @db.VarChar(10)
  MaDoiTuong   String?   @db.VarChar(10)
  TinhTrang    String    @default("Đang học") @db.VarChar(20)

  xa              XA?             @relation(fields: [MaXa], references: [MaXa])
  nganh           NGANH           @relation(fields: [MaNganh], references: [MaNganh])
  doiTuong        DOITUONGUUTIEN? @relation(fields: [MaDoiTuong], references: [MaDoiTuong])
  nguoiDung       NGUOIDUNG? // mỗi SV có tối đa 1 tài khoản đăng nhập
  phieuDangKyList PHIEUDANGKY[] // thêm ở Nhóm 5
}

/// Tài khoản đăng nhập (gồm cả SV). Mật khẩu lưu HASH bcrypt, không lưu plaintext
model NGUOIDUNG {
  TenDangNhap  String  @id @db.VarChar(50)
  MatKhau      String  @db.VarChar(255)
  VaiTro       VaiTro
  HoTen        String? @db.VarChar(100)
  MaSoSinhVien String? @unique @db.VarChar(15) // chỉ có khi VaiTro = SV
  TrangThai    Boolean @default(true) // true = đang hoạt động, false = bị khóa

  sinhVien SINHVIEN? @relation(fields: [MaSoSinhVien], references: [MaSoSinhVien])
}

// ===================== NHÓM 4: HỌC KỲ & MỞ MÔN =====================

/// Học kỳ năm học (BM8). HanDongHocPhi phục vụ QĐ10 (kiểm tra hạn đóng)
model HOCKYNAMHOC {
  MaHKNH        String   @id @db.VarChar(15)
  HocKy         String   @db.VarChar(20) // HK1 / HK2 / HK hè
  NgayBatDau    DateTime
  NgayKetThuc   DateTime
  HanDongHocPhi DateTime

  monHocMoList    MONHOCMO[] // các môn được mở trong học kỳ này
  phieuDangKyList PHIEUDANGKY[] // thêm ở Nhóm 5
}

/// Môn được mở trong một học kỳ (BM8) + sĩ số lớp (khớp pdt_dkhp.js)
model MONHOCMO {
  MaMonHocMo  String @id @db.VarChar(15)
  MaHKNH      String @db.VarChar(15)
  MaMonHoc    String @db.VarChar(10)
  SiSoToiDa   Int    @default(50)
  SiSoHienTai Int    @default(0)

  hocKyNamHoc HOCKYNAMHOC @relation(fields: [MaHKNH], references: [MaHKNH])
  monHoc      MONHOC      @relation(fields: [MaMonHoc], references: [MaMonHoc])

  @@unique([MaHKNH, MaMonHoc]) // không mở trùng một môn trong cùng học kỳ
}

// ===================== NHÓM 5: ĐĂNG KÝ & HỌC PHÍ =====================

/// Phiếu đăng ký học phần của 1 SV trong 1 học kỳ (BM9).
/// Toàn bộ cột tiền do SERVICE tính, client KHÔNG gửi lên.
model PHIEUDANGKY {
  MaPhieu          String   @id @db.VarChar(15)
  MaSoSinhVien     String   @db.VarChar(15)
  MaHKNH           String   @db.VarChar(15)
  NgayLapPhieu     DateTime @default(now())
  TongTienDK       Decimal  @default(0) @db.Decimal(12, 2) // tổng tiền các môn đăng ký
  TienMienGiam     Decimal  @default(0) @db.Decimal(12, 2) // = TongTienDK * tỷ lệ ưu tiên
  TongTienPhaiDong Decimal  @default(0) @db.Decimal(12, 2) // = TongTienDK - TienMienGiam
  SoTienDaDong     Decimal  @default(0) @db.Decimal(12, 2)
  SoTienConLai     Decimal  @default(0) @db.Decimal(12, 2) // = TongTienPhaiDong - SoTienDaDong

  sinhVien      SINHVIEN         @relation(fields: [MaSoSinhVien], references: [MaSoSinhVien])
  hocKyNamHoc   HOCKYNAMHOC      @relation(fields: [MaHKNH], references: [MaHKNH])
  ctPhieuDKList CT_PHIEUDK[] // chi tiết các môn trong phiếu
  phieuThuList  PHIEUTHUHOCPHI[] // các lần đóng tiền

  @@unique([MaSoSinhVien, MaHKNH]) // mỗi SV chỉ 1 phiếu / học kỳ
  @@index([MaHKNH]) // phục vụ báo cáo nợ HP theo học kỳ (BM12)
}

/// Chi tiết phiếu đăng ký: các môn SV đã đăng ký (n-n PHIEUDANGKY × MONHOC)
model CT_PHIEUDK {
  MaPhieuDK String @db.VarChar(15)
  MaMonHoc  String @db.VarChar(10)

  phieuDangKy PHIEUDANGKY @relation(fields: [MaPhieuDK], references: [MaPhieu])
  monHoc      MONHOC      @relation(fields: [MaMonHoc], references: [MaMonHoc])

  @@id([MaPhieuDK, MaMonHoc]) // PK kép -> chống đăng ký TRÙNG môn trong 1 phiếu
}

/// Phiếu thu học phí - mỗi lần SV đóng tiền (cho phép nhiều lần, QĐ10)
model PHIEUTHUHOCPHI {
  MaPhieuThu   String   @id @db.VarChar(15)
  MaPhieuDK    String   @db.VarChar(15)
  NgayLapPhieu DateTime @default(now())
  SoTienThu    Decimal  @db.Decimal(12, 2) // > 0, và <= SoTienConLai (kiểm ở service)

  phieuDangKy PHIEUDANGKY @relation(fields: [MaPhieuDK], references: [MaPhieu])

  @@index([MaPhieuDK])
}

// ===================== NHÓM 6: THAM SỐ HỆ THỐNG =====================

/// Lưu các quy định thay đổi được (QĐ13): tỷ lệ miễn giảm min/max, hạn đóng,
/// số lần đóng tối đa, đơn giá mặc định... Mỗi tham số là 1 cặp (tên, giá trị).
model THAMSO {
  TenThamSo String @id @db.VarChar(50)
  GiaTri    String @db.VarChar(255)
}
