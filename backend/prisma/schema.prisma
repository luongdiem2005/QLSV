generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model chuongtrinhhoc {
  MaNganh    String  @db.VarChar(10)
  MaMonHoc   String  @db.VarChar(10)
  HocKy      String  @db.VarChar(20)
  KhoaApDung String? @db.VarChar(20)
  GhiChu     String? @db.VarChar(255)
  monhoc     monhoc  @relation(fields: [MaMonHoc], references: [MaMonHoc], map: "CHUONGTRINHHOC_MaMonHoc_fkey")
  nganh      nganh   @relation(fields: [MaNganh], references: [MaNganh], map: "CHUONGTRINHHOC_MaNganh_fkey")

  @@id([MaNganh, MaMonHoc])
  @@index([MaMonHoc], map: "CHUONGTRINHHOC_MaMonHoc_fkey")
}

model ct_monhoctruoc {
  MaMonHoc                                    String @db.VarChar(10)
  MaMonHocTruoc                               String @db.VarChar(10)
  monhoc_ct_monhoctruoc_MaMonHocTruocTomonhoc monhoc @relation("ct_monhoctruoc_MaMonHocTruocTomonhoc", fields: [MaMonHocTruoc], references: [MaMonHoc], map: "CT_MONHOCTRUOC_MaMonHocTruoc_fkey")
  monhoc_ct_monhoctruoc_MaMonHocTomonhoc      monhoc @relation("ct_monhoctruoc_MaMonHocTomonhoc", fields: [MaMonHoc], references: [MaMonHoc], map: "CT_MONHOCTRUOC_MaMonHoc_fkey")

  @@id([MaMonHoc, MaMonHocTruoc])
  @@index([MaMonHocTruoc], map: "CT_MONHOCTRUOC_MaMonHocTruoc_fkey")
}

model ct_phieudk {
  MaPhieuDK   String      @db.VarChar(15)
  MaMonHoc    String      @db.VarChar(10)
  monhoc      monhoc      @relation(fields: [MaMonHoc], references: [MaMonHoc], map: "CT_PHIEUDK_MaMonHoc_fkey")
  phieudangky phieudangky @relation(fields: [MaPhieuDK], references: [MaPhieu], map: "CT_PHIEUDK_MaPhieuDK_fkey")

  @@id([MaPhieuDK, MaMonHoc])
  @@index([MaMonHoc], map: "CT_PHIEUDK_MaMonHoc_fkey")
}

model doituonguutien {
  MaDoiTuong   String     @id @db.VarChar(50)
  DaXoa        Boolean    @default(false)
  TenDoiTuong  String     @unique(map: "DOITUONGUUTIEN_TenDoiTuong_key") @db.VarChar(100)
  TyLeMienGiam Decimal    @db.Decimal(5, 2)
  GhiChu       String?    @db.VarChar(255)
  sinhvien     sinhvien[]
}

model hockynamhoc {
  MaHKNH        String        @id @db.VarChar(15)
  HocKy         String        @db.VarChar(20)
  NgayBatDau    DateTime
  NgayKetThuc   DateTime
  HanDongHocPhi DateTime
  monhocmo      monhocmo[]
  phieudangky   phieudangky[]
}

model khoa {
  MaKhoa       String   @id @db.VarChar(10)
  DaXoa        Boolean  @default(false)
  TenKhoa      String   @unique(map: "KHOA_TenKhoa_key") @db.VarChar(150)
  VanPhongKhoa String?  @db.VarChar(150)
  GhiChu       String?  @db.VarChar(255)
  monhoc       monhoc[]
  nganh        nganh[]
}

model loaimonhoc {
  MaLoaiMonHoc    String   @id @db.VarChar(10)
  DaXoa           Boolean  @default(false)
  TenLoaiMonHoc   String   @unique(map: "LOAIMONHOC_TenLoaiMonHoc_key") @db.VarChar(50)
  SoTietMotTinChi Int
  SoTienMotTinChi Decimal  @db.Decimal(12, 2)
  monhoc          monhoc[]
}

model monhoc {
  MaMonHoc                                            String           @id @db.VarChar(10)
  DaXoa                                               Boolean          @default(false)
  TenMonHoc                                           String           @unique(map: "MONHOC_TenMonHoc_key") @db.VarChar(150)
  MaKhoa                                              String           @db.VarChar(10)
  MaLoaiMonHoc                                        String           @db.VarChar(10)
  SoTiet                                              Int
  chuongtrinhhoc                                      chuongtrinhhoc[]
  ct_monhoctruoc_ct_monhoctruoc_MaMonHocTruocTomonhoc ct_monhoctruoc[] @relation("ct_monhoctruoc_MaMonHocTruocTomonhoc")
  ct_monhoctruoc_ct_monhoctruoc_MaMonHocTomonhoc      ct_monhoctruoc[] @relation("ct_monhoctruoc_MaMonHocTomonhoc")
  ct_phieudk                                          ct_phieudk[]
  khoa                                                khoa             @relation(fields: [MaKhoa], references: [MaKhoa], map: "MONHOC_MaKhoa_fkey")
  loaimonhoc                                          loaimonhoc       @relation(fields: [MaLoaiMonHoc], references: [MaLoaiMonHoc], map: "MONHOC_MaLoaiMonHoc_fkey")
  monhocmo                                            monhocmo[]

  @@index([MaKhoa], map: "MONHOC_MaKhoa_fkey")
  @@index([MaLoaiMonHoc], map: "MONHOC_MaLoaiMonHoc_fkey")
}

model monhocmo {
  MaMonHocMo  String      @id @db.VarChar(15)
  DaXoa       Boolean     @default(false)
  MaHKNH      String      @db.VarChar(15)
  MaMonHoc    String      @db.VarChar(10)
  SiSoToiDa   Int         @default(50)
  SiSoHienTai Int         @default(0)
  hockynamhoc hockynamhoc @relation(fields: [MaHKNH], references: [MaHKNH], map: "MONHOCMO_MaHKNH_fkey")
  monhoc      monhoc      @relation(fields: [MaMonHoc], references: [MaMonHoc], map: "MONHOCMO_MaMonHoc_fkey")

  @@index([MaMonHoc], map: "MONHOCMO_MaMonHoc_fkey")
}

model nganh {
  MaNganh        String           @id @db.VarChar(10)
  DaXoa          Boolean          @default(false)
  TenNganh       String           @unique(map: "NGANH_TenNganh_key") @db.VarChar(150)
  MaKhoa         String           @db.VarChar(10)
  GhiChu         String?          @db.VarChar(255)
  chuongtrinhhoc chuongtrinhhoc[]
  khoa           khoa             @relation(fields: [MaKhoa], references: [MaKhoa], map: "NGANH_MaKhoa_fkey")
  sinhvien       sinhvien[]

  @@index([MaKhoa], map: "NGANH_MaKhoa_fkey")
}

model nguoidung {
  TenDangNhap  String           @id @db.VarChar(50)
  MatKhau      String           @db.VarChar(255)
  VaiTro       nguoidung_VaiTro
  HoTen        String?          @db.VarChar(100)
  MaSoSinhVien String?          @unique(map: "NGUOIDUNG_MaSoSinhVien_key") @db.VarChar(15)
  TrangThai    Boolean          @default(true)
  sinhvien     sinhvien?        @relation(fields: [MaSoSinhVien], references: [MaSoSinhVien], map: "NGUOIDUNG_MaSoSinhVien_fkey")
}

model phieudangky {
  MaPhieu          String           @id @db.VarChar(15)
  MaSoSinhVien     String           @db.VarChar(15)
  MaHKNH           String           @db.VarChar(15)
  NgayLapPhieu     DateTime         @default(now())
  TongTienDK       Decimal          @default(0.00) @db.Decimal(12, 2)
  TienMienGiam     Decimal          @default(0.00) @db.Decimal(12, 2)
  TongTienPhaiDong Decimal          @default(0.00) @db.Decimal(12, 2)
  SoTienDaDong     Decimal          @default(0.00) @db.Decimal(12, 2)
  SoTienConLai     Decimal          @default(0.00) @db.Decimal(12, 2)
  ct_phieudk       ct_phieudk[]
  hockynamhoc      hockynamhoc      @relation(fields: [MaHKNH], references: [MaHKNH], map: "PHIEUDANGKY_MaHKNH_fkey")
  sinhvien         sinhvien         @relation(fields: [MaSoSinhVien], references: [MaSoSinhVien], map: "PHIEUDANGKY_MaSoSinhVien_fkey")
  phieuthuhocphi   phieuthuhocphi[]

  @@unique([MaSoSinhVien, MaHKNH], map: "PHIEUDANGKY_MaSoSinhVien_MaHKNH_key")
  @@index([MaHKNH], map: "PHIEUDANGKY_MaHKNH_idx")
}

model phieuthuhocphi {
  MaPhieuThu   String      @id @db.VarChar(15)
  MaPhieuDK    String      @db.VarChar(15)
  NgayLapPhieu DateTime    @default(now())
  SoTienThu    Decimal     @db.Decimal(12, 2)
  phieudangky  phieudangky @relation(fields: [MaPhieuDK], references: [MaPhieu], map: "PHIEUTHUHOCPHI_MaPhieuDK_fkey")

  @@index([MaPhieuDK], map: "PHIEUTHUHOCPHI_MaPhieuDK_idx")
}

model sinhvien {
  MaSoSinhVien   String          @id @db.VarChar(15)
  DaXoa          Boolean         @default(false)
  HoTen          String          @db.VarChar(100)
  KhoaHoc        String?         @db.VarChar(10)
  NgaySinh       DateTime?
  GioiTinh       String?         @db.VarChar(10)
  SoDienThoai    String?         @db.VarChar(15)
  Email          String?         @unique(map: "SINHVIEN_Email_key") @db.VarChar(100)
  MaXa           String?         @db.VarChar(10)
  MaNganh        String          @db.VarChar(10)
  MaDoiTuong     String?         @db.VarChar(10)
  TinhTrang      String          @default("Đang học") @db.VarChar(20)
  nguoidung      nguoidung?
  phieudangky    phieudangky[]
  doituonguutien doituonguutien? @relation(fields: [MaDoiTuong], references: [MaDoiTuong], map: "SINHVIEN_MaDoiTuong_fkey")
  nganh          nganh           @relation(fields: [MaNganh], references: [MaNganh], map: "SINHVIEN_MaNganh_fkey")
  xa             xa?             @relation(fields: [MaXa], references: [MaXa], map: "SINHVIEN_MaXa_fkey")

  @@index([MaDoiTuong], map: "SINHVIEN_MaDoiTuong_fkey")
  @@index([MaNganh], map: "SINHVIEN_MaNganh_fkey")
  @@index([MaXa], map: "SINHVIEN_MaXa_fkey")
}

model thamso {
  TenThamSo String @id @db.VarChar(50)
  GiaTri    String @db.VarChar(255)
}

model tinh {
  MaTinh  String  @id @db.VarChar(10)
  DaXoa   Boolean @default(false)
  TenTinh String  @unique(map: "TINH_TenTinh_key") @db.VarChar(100)
  xa      xa[]
}

model xa {
  MaXa          String     @id @db.VarChar(10)
  DaXoa         Boolean    @default(false)
  MaTinh        String     @db.VarChar(10)
  TenXa         String     @db.VarChar(100)
  VungSauVungXa Boolean    @default(false)
  GhiChu        String?    @db.VarChar(255)
  sinhvien      sinhvien[]
  tinh          tinh       @relation(fields: [MaTinh], references: [MaTinh], map: "XA_MaTinh_fkey")

  @@unique([MaTinh, TenXa], map: "XA_MaTinh_TenXa_key")
}

enum nguoidung_VaiTro {
  ADMIN
  PDT
  PTC
  SV
}
